{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearningModule",
  "type": "object",
  "required": ["id", "title", "purpose", "outcomes", "exitCriteria"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string" },
    "purpose": { "type": "string" },
    "prerequisiteOutcomeIds": { "type": "array", "items": { "type": "string" } },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "type": { "enum": ["concept", "skill", "artifact", "diagnostic"] }
        },
        "additionalProperties": false
      }
    },
    "projectIds": { "type": "array", "items": { "type": "string" } },
    "estimatedSessionRange": {
      "type": "object",
      "properties": {
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "exitCriteria": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}

