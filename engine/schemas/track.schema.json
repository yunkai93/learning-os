{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearningTrack",
  "type": "object",
  "required": ["id", "title", "version", "status", "goal", "moduleIds"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string" },
    "version": { "type": "string" },
    "status": { "enum": ["draft", "ready", "active", "retired"] },
    "goal": { "type": "string" },
    "targetLevel": { "type": "string" },
    "learnerAssumptions": { "type": "array", "items": { "type": "string" } },
    "moduleIds": { "type": "array", "items": { "type": "string" } },
    "projectIds": { "type": "array", "items": { "type": "string" } },
    "rubricIds": { "type": "array", "items": { "type": "string" } },
    "capstoneProjectId": { "type": ["string", "null"] },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": false
}

